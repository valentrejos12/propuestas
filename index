<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Propuesta SEO + Mantenimiento — Origen Legal × </title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #093948;
    --navy-mid: #0c4555;
    --navy-light: #0f5265;
    --gold: #A0AF51;
    --gold-light: #b8c470;
    --off-white: #f4f6eb;
    --cream: #edf0e0;
    --muted: #7a9094;
    --border: rgba(160,175,81,0.25);
    --border-light: rgba(160,175,81,0.12);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--off-white);
    color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.7;
  }

  /* ── COVER ── */
  .cover {
    background: var(--navy);
    padding: 64px 60px 56px;
    min-height: 380px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }
  .cover::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    border-radius: 50%;
    border: 1px solid rgba(160,175,81,0.1);
  }
  .cover::after {
    content: '';
    position: absolute;
    bottom: -60px; left: 36%;
    width: 260px; height: 260px;
    border-radius: 50%;
    border: 1px solid rgba(160,175,81,0.06);
  }
  .cover-top { display: flex; justify-content: space-between; align-items: flex-start; position: relative; z-index: 2; }
  .cover-studio { font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); }
  .cover-doc { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }
  .cover-main { position: relative; z-index: 2; padding-top: 44px; }
  .cover-eyebrow { font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; }
  .cover-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(52px, 7vw, 80px);
    font-weight: 300; color: var(--off-white);
    line-height: 1.0; letter-spacing: -0.02em;
  }
  .cover-title em { font-style: italic; color: var(--gold); }
  .cover-sub { margin-top: 16px; font-size: 13px; color: rgba(244,241,235,0.4); letter-spacing: 0.08em; }
  .cover-bottom {
    display: flex; justify-content: space-between; align-items: flex-end;
    padding-top: 36px; border-top: 1px solid rgba(160,175,81,0.15);
    margin-top: 44px; position: relative; z-index: 2;
  }
  .cover-meta { font-size: 12px; color: var(--muted); }
  .cover-meta strong { display: block; color: var(--gold); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; margin-bottom: 3px; font-weight: 400; }

  /* ── SHARED ── */
  .wrap { max-width: 960px; margin: 0 auto; padding: 0 60px; }

  .sec-label {
    font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold);
    display: flex; align-items: center; gap: 14px; margin-bottom: 28px;
  }
  .sec-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  .sec-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(34px, 4.5vw, 52px); font-weight: 300;
    line-height: 1.1; letter-spacing: -0.01em; margin-bottom: 20px;
  }
  .sec-title em { font-style: italic; color: var(--gold); }

  .lead { font-size: 14px; color: #3a4452; max-width: 620px; line-height: 1.9; margin-bottom: 44px; }

  hr.gold { border: none; height: 1px; background: var(--border); margin: 0; }

  /* ── DIAGNÓSTICO ── */
  .diag-block { padding: 72px 60px; }
  .diag-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; background: var(--border); margin-top: 8px; }
  .diag-card { padding: 32px 28px; background: var(--off-white); }
  .diag-card.dark { background: var(--navy); }
  .diag-tag { font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .diag-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 400; color: var(--navy); margin-bottom: 10px; }
  .diag-card.dark .diag-title { color: var(--off-white); }
  .diag-text { font-size: 13px; color: #4a5566; line-height: 1.8; }
  .diag-card.dark .diag-text { color: rgba(244,241,235,0.5); }

  /* ── SERVICIOS ── */
  .serv-block { background: var(--navy); padding: 72px 60px; }
  .serv-block .sec-label { color: var(--gold); }
  .serv-block .sec-label::after { background: rgba(160,175,81,0.18); }
  .serv-block .sec-title { color: var(--off-white); }
  .serv-block .lead { color: rgba(244,241,235,0.5); }

  .serv-list { display: flex; flex-direction: column; gap: 0; }
  .serv-row {
    display: grid; grid-template-columns: 56px 1fr auto;
    align-items: start; gap: 28px;
    padding: 36px 0;
    border-bottom: 1px solid rgba(160,175,81,0.12);
  }
  .serv-row:first-child { border-top: 1px solid rgba(160,175,81,0.12); }
  .serv-num { font-family: 'Cormorant Garamond', serif; font-size: 13px; color: var(--gold); padding-top: 4px; letter-spacing: 0.1em; }
  .serv-name { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 400; color: var(--off-white); margin-bottom: 10px; letter-spacing: -0.01em; }
  .serv-desc { font-size: 13px; color: rgba(244,241,235,0.45); line-height: 1.8; max-width: 560px; }
  .serv-items { margin-top: 12px; display: flex; flex-direction: column; gap: 5px; }
  .serv-item { font-size: 12px; color: rgba(244,241,235,0.35); padding-left: 16px; position: relative; line-height: 1.6; }
  .serv-item::before { content: '→'; position: absolute; left: 0; color: var(--gold); font-size: 10px; top: 2px; }
  .serv-tag { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(160,175,81,0.3); padding: 5px 14px; white-space: nowrap; align-self: flex-start; margin-top: 4px; }

  /* ── AI SEO EXPLICACIÓN ── */
  .ai-block { padding: 72px 60px; background: var(--cream); }
  .ai-intro {
    background: var(--navy);
    padding: 32px 36px;
    border-left: 2px solid var(--gold);
    margin-bottom: 40px;
  }
  .ai-intro p { font-size: 14px; color: rgba(244,241,235,0.65); line-height: 1.9; font-style: italic; }
  .ai-intro strong { color: var(--gold); font-style: normal; }

  .ai-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .ai-card { border: 1px solid var(--border); padding: 28px 24px; background: var(--off-white); }
  .ai-icon { font-size: 22px; margin-bottom: 14px; }
  .ai-title { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 400; color: var(--navy); margin-bottom: 10px; }
  .ai-text { font-size: 12px; color: #4a5566; line-height: 1.8; }

  /* ── PALABRAS CLAVE ── */
  .kw-block { padding: 72px 60px; }
  .kw-table { width: 100%; border-collapse: collapse; margin-top: 8px; }
  .kw-table th { text-align: left; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); padding: 12px 16px; border-bottom: 1px solid var(--border); font-weight: 400; }
  .kw-table td { padding: 14px 16px; font-size: 13px; color: #3a4452; border-bottom: 1px solid rgba(160,175,81,0.08); vertical-align: top; line-height: 1.6; }
  .kw-table tr:last-child td { border-bottom: none; }
  .kw-badge { display: inline-block; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; padding: 3px 9px; font-weight: 500; }
  .kw-ai { background: #162238; color: var(--gold); }
  .kw-google { background: var(--cream); color: var(--navy); border: 1px solid var(--border); }
  .kw-both { background: var(--gold); color: var(--navy); }

  /* ── INVERSIÓN ── */
  .inv-block { background: var(--navy); padding: 72px 60px; }
  .inv-block .sec-label { color: var(--gold); }
  .inv-block .sec-label::after { background: rgba(160,175,81,0.18); }
  .inv-block .sec-title { color: var(--off-white); }

  .inv-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: rgba(160,175,81,0.15); margin-top: 40px; }
  .inv-card { background: var(--navy-mid); padding: 36px 28px; }
  .inv-card.featured { background: var(--gold); }
  .inv-plan { font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .inv-card.featured .inv-plan { color: rgba(14,26,43,0.6); }
  .inv-price { font-family: 'Cormorant Garamond', serif; font-size: 48px; font-weight: 300; color: var(--off-white); line-height: 1; margin-bottom: 6px; letter-spacing: -0.02em; }
  .inv-card.featured .inv-price { color: var(--navy); }
  .inv-period { font-size: 12px; color: var(--muted); margin-bottom: 24px; }
  .inv-card.featured .inv-period { color: rgba(14,26,43,0.5); }
  .inv-includes { display: flex; flex-direction: column; gap: 8px; }
  .inv-line { display: flex; align-items: flex-start; gap: 10px; font-size: 12px; color: rgba(244,241,235,0.6); line-height: 1.6; }
  .inv-card.featured .inv-line { color: rgba(14,26,43,0.7); }
  .inv-line::before { content: '✓'; color: var(--gold); flex-shrink: 0; font-size: 11px; margin-top: 1px; }
  .inv-card.featured .inv-line::before { color: var(--navy); }
  .inv-note { margin-top: 32px; font-size: 12px; color: rgba(244,241,235,0.35); font-style: italic; line-height: 1.8; }

  /* ── TÉRMINOS ── */
  .terms-block { padding: 72px 60px; }
  .terms-list { display: flex; flex-direction: column; gap: 0; margin-top: 8px; }
  .term-item { display: grid; grid-template-columns: 44px 1fr; gap: 20px; padding: 20px 0; border-bottom: 1px solid var(--border); }
  .term-num { font-family: 'Cormorant Garamond', serif; font-size: 12px; color: var(--gold); padding-top: 2px; }
  .term-text { font-size: 13px; color: #4a5566; line-height: 1.8; }

  /* ── CLOSING ── */
  .closing { background: var(--navy); padding: 80px 60px; display: flex; justify-content: space-between; align-items: flex-end; }
  .closing-eyebrow { font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .closing-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 5vw, 60px); font-weight: 300; color: var(--off-white); line-height: 1.05; letter-spacing: -0.02em; }
  .closing-title em { font-style: italic; color: var(--gold); }
  .closing-note { margin-top: 16px; font-size: 13px; color: rgba(244,241,235,0.4); max-width: 380px; line-height: 1.8; }
  .closing-right { text-align: right; }
  .closing-studio { font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
  .closing-detail { font-size: 12px; color: var(--muted); line-height: 1.8; }

  /* ── SINGLE PLAN ── */
  .inv-single { border: 1px solid rgba(160,175,81,0.3); overflow: hidden; margin-top: 40px; }
  .inv-single-header {
    background: var(--navy-mid);
    padding: 40px 48px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .inv-plan-label { font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
  .inv-plan-sub { font-size: 12px; color: var(--muted); letter-spacing: 0.05em; }
  .inv-single-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 56px; font-weight: 300; color: var(--off-white);
    line-height: 1; letter-spacing: -0.02em;
  }
  .inv-single-price sup { font-size: 24px; vertical-align: super; color: var(--gold); }
  .inv-single-price sub { font-size: 14px; vertical-align: baseline; color: var(--muted); }
  .inv-single-body { padding: 40px 48px; background: rgba(9,57,72,0.04); }
  .inv-single-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px 40px;
  }
  .inv-single-grid .inv-line {
    border-bottom: 1px solid rgba(160,175,81,0.15);
    padding: 10px 0; color: #3a4452;
  }
  .inv-single-grid .inv-line::before { color: var(--gold); }

</style>
</head>
